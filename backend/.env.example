# 复制此文件为 .env 并修改为你的配置
JWT_SECRET=medical-platform-jwt-secret-change-in-production
PORT=3001
FRONTEND_URL=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medical_consultation?schema=public
SMS_DEBUG_CODE=false
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
TENCENTCLOUD_SMS_APP_ID=
TENCENTCLOUD_SMS_SIGN_NAME=
TENCENTCLOUD_SMS_TEMPLATE_ID=
TENCENTCLOUD_SMS_REGION=ap-guangzhou

# ── AI 配置（至少填 AI_API_KEY，其他可选）──────────────────────────────────
# OpenAI
# AI_API_KEY=sk-xxxxxxxxxxxxxxxx
# AI_API_BASE=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# DeepSeek（推荐，便宜且中文效果好）
# AI_API_KEY=sk-xxxxxxxxxxxxxxxx
# AI_API_BASE=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat

# 通义千问（阿里云）
# AI_API_KEY=sk-xxxxxxxxxxxxxxxx
# AI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# AI_MODEL=qwen-plus
